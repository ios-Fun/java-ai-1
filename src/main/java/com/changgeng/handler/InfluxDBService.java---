    // 执行ck的查询
    public void queryClickHouse() {
        try {
            Class.forName("ru.yandex.clickhouse.ClickHouseDriver");
            Connection connection = DriverManager.getConnection(CLICKHOUSE_URL, CLICKHOUSE_USER, CLICKHOUSE_PASSWORD);
            Statement statement = connection.createStatement();
            String sqlStr = "select * from RealTimeData where time > '2022-12-31 13:20:00' and time < '2023-11-01 00:00:00' and tagName in ('ST2CrhExtSF', 'ST2CrhExtSH', 'ST2CrhExtST0', 'ST2CycWInT', 'ST2CycWOutT', 'ST2FFWF', 'ST2FFWH', 'ST2FFWQ','ST2GR','AmbP', 'Comp1InAirH', 'Comp1InAirP', 'Comp1InAirT', 'Comp1OutAirH', 'Comp1OutAirHs', 'Comp1OutAirP', 'Comp1OutAirT')";
            StopWatch stopWatch = new StopWatch();
            stopWatch.start();
            ResultSet resultSet =statement.executeQuery(sqlStr);
            int count = 0;
            while (resultSet.next()) {
                count += 1;
            }
            stopWatch.stop();
            log.info("time:"+ stopWatch.getTotalTimeMillis() + "," + count);

        } catch (SQLException | ClassNotFoundException e) {
            e.printStackTrace();
        }

    }

    public String afterTenMinutes(String dateStr) {
        SimpleDateFormat sdf = new SimpleDateFormat("yyyy-MM-dd'T'HH:mm:ss'Z'");
        sdf.setTimeZone(TimeZone.getTimeZone("UTC"));
        try {
            Date utilDate = sdf.parse(dateStr);
            Calendar calendar = Calendar.getInstance();
            calendar.setTime(utilDate);
            calendar.add(Calendar.MINUTE, smsConfig.minutes);

            Date afterTime = calendar.getTime();
            return sdf.format(afterTime);
        } catch (ParseException e) {
            e.printStackTrace();
            return "";
        }

    }

